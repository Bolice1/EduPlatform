# ============================================
# GISHOMA ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://yourdomain.com

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Railway automatically provides DATABASE_URL
# For manual configuration, use:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=Gishoma

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
# Generate secure random strings (min 64 chars):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here_min_64_chars_required
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_64_chars_required

# ============================================
# OPTIONAL SECURITY FEATURES
# ============================================
# Data encryption at rest (optional)
# ENCRYPTION_KEY=your_encryption_key_32_chars

# Database SSL/TLS (optional, for cloud databases)
# DB_SSL=true

# Password hashing rounds (default: 12, min: 12)
# BCRYPT_ROUNDS=12

# Brute force protection (default: 5 attempts)
# MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes (default: 15)
# LOCKOUT_DURATION_MINUTES=15

# Logging directory (default: ./logs)
# LOG_DIR=/var/log/gishoma

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# For automated email notifications (announcements, password reset, etc.)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_specific_password
# EMAIL_SERVICE=gmail

# ============================================
# RAILWAY-SPECIFIC VARIABLES
# ============================================
# These are automatically set by Railway:
# - DATABASE_URL: Connection string for MySQL
# - PORT: Dynamic port assignment
# - NODE_ENV: Deployment environment

# Optional Railway region (defaults to auto-selected):
# RAILWAY_REGION=us-west
